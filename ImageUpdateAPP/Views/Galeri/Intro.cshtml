@{
    ViewData["Title"] = "Intro";
}

<div class="container py-5">

    <h1 class="mb-5 text-center fw-bold">
        Image Upload MVC Project
    </h1>

    <div class="card shadow border-0 mb-5">
        <div class="card-body">

            <h3 class="fw-bold mb-3">
                IActionResult Index()
            </h3>

            <p class="text-muted">
                This action returns all uploaded images and displays them inside gallery container.
            </p>

            <div class="bg-dark text-light rounded p-3 position-relative">

                <span class="position-absolute top-0 end-0 badge bg-primary m-2">
                    C#
                </span>

<pre class="m-0"><code>
public IActionResult Index()
{
    var images = _fileService.GetAllImages();

    return View(images);
}
</code></pre>

            </div>

        </div>
    </div>

    <div class="card shadow border-0 mb-5">
        <div class="card-body">

            <h3 class="fw-bold mb-3">
                SaveImageAsync()
            </h3>

            <p class="text-muted">
                This method uploads image files into wwwroot/images folder.
            </p>

            <div class="bg-dark text-light rounded p-3 position-relative">

                <span class="position-absolute top-0 end-0 badge bg-success m-2">
                    C#
                </span>

<pre class="m-0"><code>
public async Task&lt;string&gt; SaveImageAsync(IFormFile file)
{
    var uploadsFolder = Path.Combine(
        _environment.WebRootPath,
        "images"
    );

    Directory.CreateDirectory(uploadsFolder);

    var fileName = Guid.NewGuid() +
                   Path.GetExtension(file.FileName);

    var filePath = Path.Combine(
        uploadsFolder,
        fileName
    );

    using var stream = new FileStream(
        filePath,
        FileMode.Create
    );

    await file.CopyToAsync(stream);

    return fileName;
}
</code></pre>

            </div>

        </div>
    </div>

    <div class="card shadow border-0 mb-5">
        <div class="card-body">

            <h3 class="fw-bold mb-3">
                Docker Volume
            </h3>

            <p class="text-muted">
                Docker volume configuration for persistent image storage.
            </p>

            <div class="bg-dark text-light rounded p-3 position-relative">

                <span class="position-absolute top-0 end-0 badge bg-warning text-dark m-2">
                    YAML
                </span>

<pre class="m-0"><code>
volumes:
  - ./wwwroot/images:/app/wwwroot/images
</code></pre>

            </div>

        </div>
    </div>

</div>