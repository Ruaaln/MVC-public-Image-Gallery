@model List<string>

<div class="container">
    <div>
        <a asp-action="Update" asp-controller="Galeri" class="btn btn-primary mb-3">
			Add New Image
		</a>
    </div>
    <div class="row">

        @foreach (var image in Model)
        {
            <div class="col-md-3 mb-4 img-box">
                <div class="card">
                    <img
                        src="/images/@image"
                        class="card-img-top"
                        style="height:250px; object-fit:cover;"
                    />
                </div>
            </div>
        }

    </div>
</div> 

